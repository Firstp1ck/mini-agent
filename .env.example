# Which LLM backend to use. The agent prompts you to choose on first run if missing.
# Supported values: anthropic, openai
# MINI_AGENT_PROVIDER=anthropic

# Extended thinking / reasoning effort, applied to whichever backend is in use.
# On first full setup, the CLI or GUI prompts for this after the model is chosen
# if the variable is missing from `.env`. The picker only offers the levels
# the selected provider and model accept:
#   - Claude Opus 4.7:                         auto, off, low, medium, high, max, xhigh
#   - Claude Opus 4.6 / Sonnet 4.6 / Mythos:   auto, off, low, medium, high, max  (adaptive)
#   - Claude Opus 4.5 / Sonnet 4.5 / Haiku 4.5: auto, off, low, medium, high, max  (manual budget_tokens)
#   - Older Claude 3.x:                        auto, off, low, medium, high, max  (manual budget_tokens)
#   - GPT-5 family + o-series (o1 / o3 / o4):  auto, off, low, medium, high, max, xhigh
#   - GPT-4o / GPT-4 / chatgpt-* / GPT-3.5:    auto, off  (no reasoning parameter)
#
# Mapping summary:
# - auto/unset: provider's API default. Adaptive Claude models get
#   `thinking:{type:adaptive}` with no explicit effort; manual-thinking Claude
#   models get no thinking config (so thinking is off by default); GPT-5 family
#   uses `medium` reasoning by default.
# - off:        no thinking config on either provider; reasoning.effort=none on GPT.
# - low/medium/high/max: explicit effort on adaptive Claude / reasoning GPT;
#   on manual-thinking Claude models the level maps to a budget_tokens budget
#   (~2k / 4k / 8k / 12k) sent as `thinking:{type:enabled, budget_tokens:N}`.
# - xhigh:      Claude Opus 4.7 + GPT-5 family / o-series only.
# MINI_AGENT_THINKING=auto

# --- Anthropic (Claude) ---
# Used when MINI_AGENT_PROVIDER=anthropic. The agent prompts on first run if missing.
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY
# Current balanced default: claude-sonnet-4-6
# More capable/costlier:    claude-opus-4-7
# Faster/cheaper:           claude-haiku-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (GPT) ---
# Used when MINI_AGENT_PROVIDER=openai. The agent prompts on first run if missing.
# OPENAI_API_KEY=YOUR-OPENAI-API-KEY
# Current flagship default: gpt-5.5
# Faster/cheaper:           gpt-5.4-mini
# Smallest/cheapest:        gpt-5.4-nano
# OPENAI_MODEL=gpt-5.5
